{
  "name": "api",
  "version": "1.0.0",
  "description": "api for a mobile app that helps with reporting lost pets and posting sightings",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon -L ./index.js",
    "start": "node ./index.js",
    "setup-db": "node ./database/setup.js",
    "test": "jest --watchAll --detectOpenHandles --runInBand --verbose",
    "unitTests": "jest --testPathPatterns=/unit/ --watchAll --verbose",
    "integrationTests": "jest --testPathPatterns=/integration/ --watchAll --detectOpenHandles --runInBand --verbose",
    "coverage": "jest --coverage --testPathPatterns=/unit/"
  },
